# API Key para proteger los endpoints — generar una segura para producción
BG_API_KEY=cambiar-por-clave-segura

# OpenRouter (Gemini 2.0 Flash) — resolver captcha del Ministerio de Educación
OPENROUTER_API_KEY=sk-or-v1-xxx

# WebShare Rotating Residential — proxy IPs de Ecuador (para Bachiller)
# Formato: http://USUARIO-cc-ec:PASSWORD@p.webshare.io:80
WEBSHARE_PROXY_URL=http://USUARIO-cc-ec:PASSWORD@p.webshare.io:80

# ── Proxies para Fiscalía (Incapsula) ────────────────────────────────────────
# Opción A — Proxy único (modo viejo, solo 1 IP):
#   FISCALIA_PROXY_URL=http://ec.decodo.com:20001
#   FISCALIA_PROXY_USER=usuario
#   FISCALIA_PROXY_PASS=password
#
# Opción B (RECOMENDADO) — Pool de proxies para rotación entre reintentos:
#   FISCALIA_PROXY_LIST_FILE=/app/proxies.csv
#   (Archivo con una linea por proxy: host:port:user:pass)
#   En Easypanel: subir el archivo via Files o montarlo como volumen.
#
# Opción C — Lista inline en env var (alternativa si no querés archivo):
#   FISCALIA_PROXY_LIST=host1:port:user:pass,host2:port:user:pass,...
#
# Con pool: si un IP es bloqueado, el siguiente intento usa otro automáticamente.

# Límites del endpoint /consultar/batch
MAX_BATCH_SIZE=50
SEMAPHORE=3
