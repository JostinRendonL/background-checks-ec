# API Key para proteger los endpoints — generar una segura para producción
BG_API_KEY=cambiar-por-clave-segura

# OpenRouter (Gemini 2.0 Flash) — resolver captcha del Ministerio de Educación
OPENROUTER_API_KEY=sk-or-v1-xxx

# WebShare Rotating Residential — proxy IPs de Ecuador (para Bachiller)
# Formato: http://USUARIO-cc-ec:PASSWORD@p.webshare.io:80
WEBSHARE_PROXY_URL=http://USUARIO-cc-ec:PASSWORD@p.webshare.io:80

# Límites del endpoint /consultar/batch
MAX_BATCH_SIZE=50
SEMAPHORE=3
